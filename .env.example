# Environment Variables Configuration for Code Explainer
# Copy to .env and fill in appropriate values for local development

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_KEY=dev-key-change-in-production-12345

# Database Configuration (PostgreSQL for production)
DATABASE_URL=postgresql://codeexplainer:changeme@localhost:5432/code_explainer
# Alternative for SQLite (development only)
# DATABASE_URL=sqlite:///./code_explainer.db
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis Configuration (for caching)
REDIS_URL=redis://localhost:6379/0
REDIS_TTL=3600

# Model Configuration
MODEL_NAME=codet5-base
CODE_EXPLAINER_MODEL_PATH=./results
CODE_EXPLAINER_CONFIG_PATH=./configs/default.yaml
CODE_EXPLAINER_PRECISION=fp16  # Options: fp32, fp16, bf16, 8bit
CODE_EXPLAINER_DEVICE=cuda  # Options: cuda, mps, cpu

# Logging Configuration
LOG_LEVEL=INFO  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_DIR=/var/log/code-explainer

# Feature Flags
ENABLE_CACHE=true
ENABLE_MONITORING=true
ENABLE_AUDIT_LOGGING=true

# Security Configuration
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:8501,http://localhost:7860
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# SSL/TLS Configuration (for production HTTPS)
SSL_ENABLED=false
# SSL_CERT_PATH=/etc/ssl/certs/cert.pem
# SSL_KEY_PATH=/etc/ssl/private/key.pem

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=8001

# Application Version (set by CI/CD)
APP_VERSION=1.0.0

# Grafana Configuration (for monitoring profile)
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Database Configuration (optional)
# DATABASE_URL=postgresql://user:password@localhost:5432/codeexplainer

# Redis Configuration (optional)
# REDIS_URL=redis://localhost:6379/0

# Rate Limiting (if slowapi is installed)
# RATE_LIMIT_PER_MINUTE=60

# Development Mode
DEV=false
